{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "explore": {
            "mode": "subagent",
            "model": "zai-coding-plan/glm-5-turbo"
        }
    },
    "mcp": {
        "heroui-native": {
            "type": "local",
            "command": [
                "pnpx",
                "@heroui/native-mcp@latest"
            ]
        },
        "obsidian": {
            "type": "local",
            "command": [
                "pnpx",
                "@bitbonsai/mcpvault@latest",
                "/home/shiron/Notes/Notes"
            ]
        }
    }
}